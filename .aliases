# Set personal aliases, overriding those provided by oh-my-zsh libs,
# plugins, and themes. Aliases can be placed here, though oh-my-zsh
# users are encouraged to define aliases within the ZSH_CUSTOM folder.
# For a full list of active aliases, run `alias`.
#
# Example aliases
alias zshconfig="vim ~/.zshrc"
alias ohmyzsh="vim ~/.oh-my-zsh"
alias reload="source ~/.zshrc"

# lol idk lmao
alias aliases="vim ~/.aliases"
alias exports="vim ~/.exports"
# jk those are actually needed in order to quickly edit stuff on the command line.  vim bad git gud

# https://dev.to/rawkode/tip-5-replacing-ls-with-exa-3o5n
# ls
TREE_IGNORE="cache|log|logs|node_modules|vendor"

alias ls=' exa --group-directories-first'
alias la=' ls -a'
alias ll=' ls --git -l'
alias lt=' ls --tree -D -L 2 -I ${TREE_IGNORE}'
alias ltt=' ls --tree -D -L 3 -I ${TREE_IGNORE}'
alias lttt=' ls --tree -D -L 4 -I ${TREE_IGNORE}'
alias ltttt=' ls --tree -D -L 5 -I ${TREE_IGNORE}'

# https://dev.to/rawkode/tip-3-create-a-tmp-alias-f6h
alias tmp=' cd $(mktemp -d)'


# alias ls="colorls — light — sort-dirs — report"
# alias lc="colorls — tree — light"
#alias ls="colorls"
#source $(dirname $(gem which colorls))/tab_complete.sh
# Moving this to exports as per https://github.com/athityakumar/colorls/issues/322

# VLC alias - hi, this will only work on my Mac unless I upload the start script, it starts VLC with Discord rich presence
alias vlc="/jack/Documents/VLCRP/start.sh"

alias msf="cd /opt/metasploit-framework/bin && ./msfconsole"
alias sherlock="python3 sherlock"

# Pywal
alias gw="cd ~/Pictures/Wallpapers"
# alias ww="wal -e -i"
www () 
{
    wal -e -i "$1" && pywalfox update && rm -f ~/Documents/GitHub/Bento/assets/background.jpg && cp "$1" ~/Documents/GitHub/Bento/assets/background.jpg && cd ~/Documents/GitHub/Bento && git add . && git commit -m "automated background update" && git push && gw
}

# Custom alises
alias ports="netstat -tulanp"
alias diff="colordiff"
alias mount="mount |column -t"
alias h="history"
alias j="jobs -l"
alias c="clear"
alias root="sudo -i"
alias su="sudo -i"
alias nf="clear && neofetch"
